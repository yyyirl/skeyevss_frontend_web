import React, { type ReactElement, useEffect, useRef } from 'react'
import { useHistory } from 'react-router-dom'
import { Progress, Select } from 'antd'
import * as echarts from 'echarts'
import routes, { Path } from '#routers/constants'
import { dateFormatHis, themeDark } from '#constants/appoint'
import useFetchState from '#repositories/models'
import { Theme } from '#repositories/models/recoil-state'
import { AllGroups } from '#repositories/apis/base'
import { autoConvertBits, isEmpty, throttle, timestampFormat } from '#utils/functions'
import EChats from '#components/e-chats'
import { toSelectOptionType } from '#components/table/model'
import { Item as DeviceItem } from '#pages/devices/items/model'
import { List as MSListApi } from '#pages/configs/media-server/api'
import { DefaultMSSev, type Item as MSItem } from '#pages/configs/media-server/model'
import { ServerHealth } from './api'
import { type DeviceStatistics, type DiskUsageItem } from './model'
import { type CancelTokenSourceType, getCancelSource } from '#utils/axios'

// ------------------------------ health
interface HealthChatState {
	dates: string[]
	data: number[] | number[][]
	type: 'cpu' | 'network' | 'memory'
	title: string
	isDark: boolean
}

export const Health = (): ReactElement => {
	const theme = new Theme()
	const isDark = theme.state === themeDark

	const [ memTotal, setMemTotal ] = useFetchState(0)
	const [ cpuHealth, setCpuHealth ] = useFetchState<HealthChatState>({ dates: [], data: [], type: 'cpu', title: 'CPU', isDark })
	const [ networkHealth, setNetworkHealth ] = useFetchState<HealthChatState>({ dates: [], data: [], type: 'network', title: '网络', isDark })
	const [ memHealth, setMemHealth ] = useFetchState<HealthChatState>({ dates: [], data: [], type: 'memory', title: '内存', isDark })
	const [ diskUsage, setDiskUsage ] = useFetchState<DiskUsageItem[]>([])
	const [ deviceStatistics, setDeviceStatistics ] = useFetchState<DeviceStatistics | undefined>(undefined)
	const [ accessProtocolGroup, setAccessProtocolGroup ] = useFetchState<{ [key: number]: number } | undefined>(undefined)

	const fetch = (): void => {
		void ServerHealth().then(
			res => {
				setMemTotal(res.data?.memTotal ?? 0)
				const hardware = res.data?.hardware ?? []
				const dates = hardware.map(
					item => timestampFormat(item.timestamp, dateFormatHis)
				)
				setCpuHealth({
					...cpuHealth,
					dates,
					data: hardware.map(
						item => item.cpu
					)
				})
				setNetworkHealth({
					...networkHealth,
					dates,
					data: hardware.map(
						item => [ parseFloat(item.network.upRate.toFixed(2)), parseFloat(item.network.downRate.toFixed(2)) ]
					)
				})
				setMemHealth({
					...memHealth,
					dates,
					data: hardware.map(
						item => item.mem.used
					)
				})
				setDeviceStatistics(res.data?.deviceStatistics)
				setAccessProtocolGroup(res.data?.deviceStatistics?.accessProtocolGroup)
				setDiskUsage(res.data?.diskUsage ?? [])
			}
		)
	}

	useEffect(
		() => {
			fetch()
			const interval = setInterval(
				fetch,
				3000
			)

			return () => {
				clearInterval(interval)
			}
		},
		[]
	)

	return <ul className="home-chart-box">
		<li><CDeviceStatistics isDark={ isDark } data={ deviceStatistics } /></li>
		<li><CAccessProtocolGroup isDark={ isDark } data={ accessProtocolGroup ?? {} } /></li>
		<li><HealthItem { ...cpuHealth } isDark={ isDark } max={ 100 } /></li>
		<li><HealthItem { ...networkHealth } isDark={ isDark } max={ 100 } /></li>
		<li><HealthItem { ...memHealth } isDark={ isDark } max={ memTotal } /></li>
		<li><DiskUse isDark={ isDark } data={ diskUsage } /></li>
	</ul>
}

interface LoadBalancingType {
	in: number
	out: number
}

export const CDeviceStatistics = ({ data }: { data: DeviceStatistics | undefined, isDark: boolean }): ReactElement => {
	const history = useHistory()

	const cancelTokenRef = useRef<CancelTokenSourceType | null>(null)
	const fetchGroupsIntervalRef = useRef<any>(null)

	const deviceOnlineCount = data?.deviceOnlineCount ?? 0
	const deviceOfflineCount = data?.deviceOfflineCount ?? 0
	const deviceCount = deviceOnlineCount + deviceOfflineCount

	const channelOnlineCount = data?.channelOnlineCount ?? 0
	const channelOfflineCount = data?.channelOfflineCount ?? 0
	const channelCount = channelOnlineCount + channelOfflineCount

	const [ activeMS, setActiveMS ] = useFetchState(0)
	const [ msList, setMsList ] = useFetchState<MSItem[]>([])
	const [ loadBalancing, setLoadBalancing ] = useFetchState<LoadBalancingType>({ in: 0, out: 0 })

	const fetchGroups = (): void => {
		cancelTokenRef.current?.cancel()
		cancelTokenRef.current = getCancelSource()
		void AllGroups({}, cancelTokenRef.current).then(
			res => {
				const data = { ...loadBalancing }
				const records = res.data ?? []
				records.forEach(
					item => {
						if (item.pub !== undefined && item.pub !== null && !isEmpty(item.pub.session_id)) {
							data.in += 1
						}

						if (item.pull !== undefined && item.pull !== null && !isEmpty(item.pull.session_id)) {
							data.in += 1
						}

						if (item.subs !== undefined && item.subs !== null) {
							data.out += item.subs.length
						}

						if (item.pushs !== undefined && item.pushs !== null) {
							data.out += item.pushs.length
						}
					}
				)

				setLoadBalancing(data)
				fetchGroupsIntervalRef.current = setTimeout(
					fetchGroups, 3000
				)
			}
		)
	}

	useEffect(
		() => {
			void MSListApi({ all: true }).then(
				res => {
					const list = res.data?.list ?? []
					setMsList(list)
				}
			)

			return () => {
				cancelTokenRef.current?.cancel()
				clearTimeout(fetchGroupsIntervalRef.current as number)
			}
		},
		[]
	)

	useEffect(
		() => {
			throttle(
				() => {
					cancelTokenRef.current?.cancel()
					clearTimeout(fetchGroupsIntervalRef.current as number)

					fetchGroups()
				},
				1000,
				'fetchGroups'
			)
		},
		[ activeMS ]
	)

	return <div className="device-statistics">
		<div className="title">设备信息</div>
		<div className="content">
			<div className="device">
				<Progress size={ 120 } format={ v => parseInt(`${ v ?? 0 }`) } percent={ parseFloat((deviceOnlineCount / deviceCount).toFixed(2)) * 100 } type="circle" />
				<p>在线数: { deviceOnlineCount }</p>
				<p>离线数: { deviceOfflineCount }</p>
				<p className="cursor-pointer blue" onClick={ () => { history.push(routes[ Path.devices ].subs?.[ Path.deviceItems ].path ?? '') } }>总设备数: { deviceCount }</p>
			</div>
			<div className="channel">
				<Progress size={ 120 } format={ v => parseInt(`${ v ?? 0 }`) } percent={ parseFloat((channelOnlineCount / channelCount).toFixed(2)) * 100 } type="circle" />
				<p>在线数: { channelOnlineCount }</p>
				<p>离线数: { channelOfflineCount }</p>
				<p className="cursor-pointer blue" onClick={ () => { history.push(routes[ Path.devices ].subs?.[ Path.deviceChannels ].path ?? '') } }>总通道数: { channelCount }</p>
			</div>
		</div>
		<div className="load-balancing">
			<div className="ms-list">
				<Select
					className="ms-select"
					showSearch
					value={ activeMS }
					onChange={ setActiveMS }
					optionFilterProp="label"
					options={ toSelectOptionType([ DefaultMSSev, ...msList.map(item => ({ value: item.id, title: item.name })) ]) }
				/>
			</div>
			<EChats
				options={
					{
						xAxis: {
							max: 'dataMax'
						},
						yAxis: {
							type: 'category',
							data: [ '输入', '输出' ],
							inverse: true,
							animationDuration: 300,
							animationDurationUpdate: 300,
							max: 1
						},
						grid: {
							top: '15px',
							bottom: '85px',
							left: '15px',
							containLabel: true
						},
						series: [
							{
								realtimeSort: true,
								type: 'bar',
								data: [ loadBalancing.in, loadBalancing.out ],
								label: {
									show: true,
									position: 'right',
									valueAnimation: true
								}
							}
						],
						legend: {
							show: true
						},
						animationDuration: 0,
						animationDurationUpdate: 3000,
						animationEasing: 'linear',
						animationEasingUpdate: 'linear'
					}
				}
			/>
		</div>
	</div>
}


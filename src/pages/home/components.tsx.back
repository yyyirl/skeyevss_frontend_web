/>

export const DiskUse = ({ data, isDark }: { data: DiskUsageItem[], isDark: boolean }): ReactElement => {
	const formatBytes = (bytes: number): string => {
		if (bytes === 0) return '0 B'
		const units = [ 'B', 'KB', 'MB', 'GB', 'TB' ]
		const unitIndex = Math.floor(Math.log(bytes) / Math.log(1024))
		const size = bytes / Math.pow(1024, unitIndex)

		return `${ size.toFixed(1) } ${ units[ unitIndex ] }`
	}

	// 根据使用率获取颜色
	const getColorByUsage = (percent: number): string => {
		if (percent >= 90) return '#ff4d4f'
		if (percent >= 80) return '#faad14'
		if (percent >= 60) return '#1890ff'
		return '#52c41a'
	}

	return <EChats
		className="item"
		options={
			{
				title: {
					text: '磁盘使用情况统计',
					left: 'center',
					textStyle: {
						fontSize: 16,
						fontWeight: 'bold',
						color: isDark ? 'rgba(255, 255, 255, .85)' : 'rgba(0, 0, 0, .88)'
					}
				},
				tooltip: {
					trigger: 'axis',
					axisPointer: {
						type: 'shadow'
					},
					formatter: function(params: any) {
						const usedParam = params.find((item: any) => item.seriesName === '已使用')
						const freeParam = params.find((item: any) => item.seriesName === '未使用')

						if (isEmpty(usedParam) || isEmpty(freeParam)) return ''

						const total = usedParam.value + freeParam.value
						const usedPercent = ((usedParam.value / total) * 100).toFixed(1)

						return `
							<div style="font-weight: bold; margin-bottom: 5px;">${ usedParam.name }</div>
							<div style="display: flex; align-items: center; margin: 3px 0;">
							  <span style="display: inline-block; width: 10px; height: 10px; background: ${ usedParam.color }; margin-right: 5px; border-radius: 2px;"></span>
							  <span>已使用: ${ formatBytes(usedParam.value as number) } (${ usedPercent }%)</span>
							</div>
							<div style="display: flex; align-items: center; margin: 3px 0;">
							  <span style="display: inline-block; width: 10px; height: 10px; background: ${ freeParam.color }; margin-right: 5px; border-radius: 2px;"></span>
							  <span>未使用: ${ formatBytes(freeParam.value as number) }</span>
							</div>
							<div style="margin-top: 5px; font-weight: bold;">
							  总计: ${ formatBytes(total as number) }
							</div>
						`
					}
				},
				grid: {
					left: '3%',
					right: '4%',
					bottom: '3%',
					top: '60px',
					containLabel: true
				},
				xAxis: {
					type: 'category',
					data: data.map(item => {
						const parts = item.device.split('/')
						return parts[ parts.length - 1 ] ?? item.device
					}),
					axisLabel: {
						rotate: 45,
						fontSize: 10
					},
					name: '设备路径',
					nameLocation: 'end',
					nameGap: 15,
					nameTextStyle: {
						fontSize: 12,
						fontWeight: 'bold'
					},
					boundaryGap: false
				},
				yAxis: {
					type: 'value',
					nameTextStyle: {
						fontSize: 12,
						fontWeight: 'bold'
					},
					axisLabel: {
						formatter: function(value: number) {
							return formatBytes(value)
						}
					}
				},
				series: [
					{
						name: '已使用',
						type: 'bar',
						stack: 'total',
						emphasis: {
							focus: 'series'
						},
						data: data.map(item => ({
							value: item.used_bytes,
							itemStyle: {
								color: getColorByUsage(item.used_percent)
							}
						})),
						itemStyle: {
							color: function(params: any) {
								const index = params.dataIndex
								return getColorByUsage(data[ index ].used_percent)
							}
						},
						label: {
							show: true,
							position: 'inside',
							formatter: function(params: any) {
								const percent = ((params.value / (params.value + data[ params.dataIndex ].free_bytes)) * 100).toFixed(1)
								return `${ percent }%`
							},
							color: '#fff',
							fontWeight: 'bold',
							fontSize: 10
						}
					},
					{
						name: '未使用',
						type: 'bar',
						stack: 'total',
						emphasis: {
							focus: 'series'
						},
						data: data.map(item => item.free_bytes),
						itemStyle: {
							color: '#e8eaed'
						},
						label: {
							show: true,
							position: 'top',
							formatter: function(params: any) {
								return formatBytes(params.value as number)
							},
							fontSize: 10
						}
					}
				]
				// dataZoom: [
				//	 {
				//		 type: 'inside',
				//		 start: 0,
				//		 end: 100
				//	 },
				//	 {
				//		 type: 'slider',
				//		 start: 0,
				//		 end: 100,
				//		 bottom: '80px'
				//	 }
				// ]
			}
		}
	/>
}

export const HealthItem = (props: HealthChatState & { max: number }): ReactElement => {
	const innerItem = {
		name: props.title,
		type: 'line',
		stack: 'Total',
		smooth: true,
		lineStyle: {
			width: 0
		},
		showSymbol: false,
		label: {
			show: true,
			position: 'top'
		},
		areaStyle: {
			opacity: 0.8,
			color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
				{
					offset: 0,
					color: 'rgb(224, 62, 76)'
				},
				{
					offset: 1,
					color: '#80FFA5'
				}
			])
		},
		emphasis: {
			focus: 'series'
		}
	}
	let yAxis: any = {
		type: 'value',
		max: props.max
	}
	let series: any = [
		{
			...innerItem,
			data: props.data
		}
	]
	let formatter: any = function(params: any[]) {
		if (props.max <= 0) {
			return `${ params[ 0 ].axisValue }: <span style="color: #FF0087">${ params[ 0 ].data.toFixed(2) }%</span>`
		}
		return `${ params[ 0 ].axisValue }: <span style="color: #FF0087">${ ((params[ 0 ].data / props.max) * 100).toFixed(2) }%</span>`
	}
	if (props.type === 'network') {
		const up: number[] = []
		const down: number[] = []
		for (let i = 0; i < props.data.length; i++) {
			const item = props.data[ i ] as number[]
			up.push(item[ 0 ])
			down.push(item[ 1 ])
		}
		series = [
			{ ...innerItem, name: '上行', data: up },
			{ ...innerItem, name: '下行', data: down }
		]
		yAxis = { type: 'value' }
		formatter = function(params: any[]) {
			const up = autoConvertBits(params[ 0 ].data as number)
			const down = autoConvertBits(params[ 1 ].data as number)
			return `${ params[ 0 ].axisValue }<br/>上行: <span style="color: #FF0087">${ up.value }${ up.unit }</span><br/>下行: <span style="color: #FF0087">${ down.value }${ down.unit }</span>`
		}
	}

	return <EChats
		className="item"
		options={
			{
				title: {
					text: props.title,
					textStyle: {
						color: props.isDark ? 'rgba(255, 255, 255, .85)' : 'rgba(0, 0, 0, .88)'
					}
				},
				tooltip: {
					trigger: 'axis',
					axisPointer: {
						type: 'cross',
						label: {
							backgroundColor: '#6a7985'
						}
					},
					formatter
				},
				grid: {
					left: '3%',
					right: '4%',
					bottom: '3%',
					containLabel: true
				},
				xAxis: [
					{
						type: 'category',
						boundaryGap: false,
						data: props.dates
					}
				],
				yAxis,
				series
			}
		}
	/>
}

// ------------------------------ server

enum SevType {
	cpu = 'cpu',
	mem = 'mem'
}

interface SevChatState {
	dates: string[]
	list: any[]
	headers: string[]
}

export const Server = (): ReactElement => {
	const [ memTotal, setMemTotal ] = useFetchState(0)
	const [ sevCpuList, setSevCpuList ] = useFetchState<SevChatState>({
		dates: [],
		list: [],
		headers: []
	})
	const [ sevMemList, setSevMemList ] = useFetchState<SevChatState>({
		dates: [],
		list: [],
		headers: []
	})
	const fetch = (): void => {
		void ServerHealth().then(
			res => {
				setMemTotal(res.data?.memTotal ?? 0)
				const data = res.data?.services ?? []
				const dates: string[] = []
				for (let i = 0; i < data.length; i++) {
					const v = data[ i ]
					for (let j = 0; j < v.length; j++) {
						const item = v[ j ]
						if (isEmpty(dates[ i ])) {
							dates[ i ] = timestampFormat(item.timestamp, dateFormatHis)
						}
					}
				}

				const headers: { [key: string]: string } = {}
				const maps: { [key in SevType]: { [key: string]: number[] } } = {
					mem: {},
					cpu: {}
				}
				for (let i = 0; i < data.length; i++) {
					const v = data[ i ]
					for (let j = 0; j < v.length; j++) {
						const item = v[ j ]
						if (isEmpty(maps.cpu[ item.name ])) {
							maps.cpu[ item.name ] = []
						}
						if (isEmpty(maps.mem[ item.name ])) {
							maps.mem[ item.name ] = []
						}
						if (isEmpty(headers[ item.name ])) {
							headers[ item.name ] = item.name
						}

						maps.cpu[ item.name ].push(parseFloat(item.cpu.toFixed(2)))
						maps.mem[ item.name ].push(item.mem)
					}
				}

				const sevCpuList: SevChatState = {
					dates,
					headers: Object.keys(headers),
					list: []
				}
				for (const key in maps.cpu) {
					sevCpuList.list.push(
						SevSeriesItem(maps.cpu[ key ], key)
					)
				}
				setSevCpuList(sevCpuList)

				const sevMemList: SevChatState = {
					dates,
					headers: Object.keys(headers),
					list: []
				}
				for (const key in maps.mem) {
					sevMemList.list.push(
						SevSeriesItem(maps.mem[ key ], key)
					)
				}
				setSevMemList(sevMemList)
			}
		)
	}

	useEffect(
		() => {
			fetch()
			const interval = setInterval(
				fetch,
				1000
			)

			return () => {
				clearInterval(interval)
			}
		},
		[]
	)

	return <>
		<ul className="home-chart-box">
			<li><SevItem { ...sevCpuList } max={ 100 } title="cpu" /></li>
			<li><SevItem { ...sevMemList } max={ memTotal } title="memory" /></li>
		</ul>
	</>
}

function SevSeriesItem(data: number[], name: string): any {
	return {
		name,
		type: 'line',
		stack: 'Total',
		smooth: true,
		lineStyle: {
			width: 0
		},
		showSymbol: false,
		areaStyle: {
			opacity: 0.8,
			color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
				{
					offset: 0,
					color: 'rgb(128, 255, 165)'
				},
				{
					offset: 1,
					color: 'rgb(1, 191, 236)'
				}
			])
		},
		emphasis: {
			focus: 'series'
		},
		data
	}
}

export const SevItem = (props: SevChatState & { max: number, title: string }): ReactElement => {
	return <EChats
		className="item"
		options={
			{
				color: [ '#80FFA5', '#00DDFF', '#37A2FF', '#FF0087', '#FFBF00' ],
				title: {
					text: props.title
				},
				tooltip: {
					trigger: 'axis',
					axisPointer: {
						type: 'cross',
						label: {
							backgroundColor: '#6a7985'
						}
					}
				},
				legend: {
					type: 'scroll',
					orient: 'horizontal',
					padding: [ 5, 200, 5, 0 ],
					pageIconSize: 12,
					pageTextStyle: {
						color: '#333'
					},
					data: props.headers
				},
				grid: {
					left: '3%',
					right: '4%',
					bottom: '3%',
					containLabel: true
				},
				xAxis: [
					{
						type: 'category',
						boundaryGap: false,
						data: props.dates
					}
				],
				yAxis: {
					type: 'value',
					max: props.max
				},
				series: props.list
			}
		}
	/>
}
